{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@api/*": ["apps/api/src/*"],
      "@groweasy/types": ["packages/types/src/index.ts"],
      "@groweasy/types/*": ["packages/types/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "*.config.*",
    "eslint.config.mjs"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
